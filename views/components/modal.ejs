<div class="modalContainer" id="modalContainer">
    <form class="modal" id="modal">
        <h4 class="title">Add New User</h4>
        <label>
            <input
                type="text"
                placeholder="Write First Name"
                name="firstName"
                required
            />
        </label>
        <label>
            <input
                type="text"
                placeholder="Write Last Name"
                name="lastName"
                required
            />
        </label>
        <label>
            <input type="number" placeholder="Write Age" name="age" required />
        </label>
        <label>
            <select name="gender">
                <option value="male">Male</option>
                <option value="female">Female</option>
            </select>
        </label>

        <button class="btn">Add</button>
    </form>
</div>
